{
  "name": "e2e-playwright",
  "version": "0.1.0",
  "description": "End-to-end Playwright suite for api and web applications",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report ./reports/html",
    "lint": "tsc --noEmit "
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "typescript": "7"
  },
  "devEngines": {
    "packageManager": {
      "name": "nub",
      "version": "^0.4.2",
      "onFail": "warn"
    }
  }
}
